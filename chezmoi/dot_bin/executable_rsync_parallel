#!/usr/bin/env bash
set -Eeuo pipefail

parallelism=$(/usr/sbin/sysctl -n hw.logicalcpu)

if [[ ${1-} == --parallel=* ]]; then
  parallelism=${1#*=}
  shift
fi

if [[ ! "$parallelism" =~ ^[1-9][0-9]*$ ]]; then
  echo "--parallel must be a positive integer" >&2
  exit 2
fi

reject_option() {
  echo "unsupported rsync option: $1" >&2
  exit 2
}

options=()
transfer_options=()
archive=0
while (( $# > 0 )) && [[ $1 != -- ]]; do
  case "$1" in
  -e)
    if (( $# < 2 )) || [[ $2 == -- ]]; then
      reject_option "$1"
    fi
    options+=("$1" "$2")
    transfer_options+=("$1" "$2")
    shift 2
    ;;
  --*)
    reject_option "$1"
    ;;
  -?*)
    flags=${1#-}
    [[ "$flags" =~ ^[azvhP]+$ ]] || reject_option "$1"
    [[ "$flags" == *a* ]] && archive=1
    options+=("$1")
    transfer_flags=${flags//a/}
    [[ -n "$transfer_flags" ]] && transfer_options+=("-$transfer_flags")
    shift
    ;;
  *)
    reject_option "$1"
    ;;
  esac
done

if (( $# != 3 )); then
  echo "Usage: rsync_parallel [--parallel=N] [-azvhP] [-e command] -- source destination/" >&2
  exit 2
fi

if (( archive == 0 )); then
  echo "rsync option -a is required" >&2
  exit 2
fi

transfer_options+=(-lptgoD)

shift
source=$1
destination=$2

if [[ "$destination" != */ ]]; then
  echo "destination must end in /" >&2
  exit 2
fi

transfer_source=$source
if [[ "$source" != */ ]]; then
  if [[ "$source" == *:* ]]; then
    remote=${source%:*}:
    remote_path=${source##*:}
    if [[ "$remote_path" == */* ]]; then
      transfer_source="$remote${remote_path%/*}/"
    else
      transfer_source=$remote
    fi
  elif [[ "$source" == */* ]]; then
    transfer_source="${source%/*}/"
  else
    transfer_source=./
  fi
fi

tmpdir=$(mktemp -d)
pids=()

cleanup() {
  rm -rf "$tmpdir"
}

stop() {
  trap - INT TERM
  for pid in "${pids[@]}"; do
    kill "$pid" 2>/dev/null || true
  done
  exit 130
}

trap cleanup EXIT
trap stop INT TERM

separator=$'\x1f'
echo "Determining files for $parallelism parallel transfers"
rsync "${options[@]}" --out-format="%l${separator}%n" --no-progress --no-v --dry-run "$source" "$destination" \
  | sort --field-separator="$separator" --key=1,1nr \
  >"$tmpdir/files"

total_files=$(wc -l <"$tmpdir/files" | tr -d ' ')
total_size=$(awk -F "$separator" '{ total += $1 } END { print total + 0 }' "$tmpdir/files")
echo "$total_files files, $(( total_size / 1024 / 1024 )) MB"

if (( total_files == 0 )); then
  exit 0
fi

declare -a chunk_sizes
for ((i = 0; i < parallelism; i++)); do
  chunk_sizes[i]=0
done

while IFS="$separator" read -r file_size file_path; do
  if [[ ! "$file_size" =~ ^[0-9]+$ || -z "$file_path" ]]; then
    echo "unsupported rsync output or filename" >&2
    exit 1
  fi

  smallest=0
  for ((i = 1; i < parallelism; i++)); do
    if (( chunk_sizes[i] < chunk_sizes[smallest] )); then
      smallest=$i
    fi
  done

  chunk_sizes[smallest]=$(( chunk_sizes[smallest] + file_size ))
  printf '%s\n' "$file_path" >>"$tmpdir/chunk.$smallest"
done <"$tmpdir/files"

for ((i = 1; i < parallelism; i += 2)); do
  chunk="$tmpdir/chunk.$i"
  if [[ -f "$chunk" ]]; then
    /usr/bin/tail -r "$chunk" >"$chunk.reversed"
    mv "$chunk.reversed" "$chunk"
  fi
done

for chunk in "$tmpdir"/chunk.*; do
  rsync "${transfer_options[@]}" --files-from="$chunk" "$transfer_source" "$destination" &
  pids+=("$!")
done

result=0
for pid in "${pids[@]}"; do
  wait "$pid" || result=1
done

if (( result != 0 )); then
  exit "$result"
fi

rsync "${options[@]}" --include='*/' --exclude='*' "$source" "$destination"
