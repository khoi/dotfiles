#!/bin/sh
set -eu

mise_bin="{{ .chezmoi.homeDir }}/.local/bin/mise"
required_version="{{ (include "dot_config/mise/config.toml" | fromToml).min_version }}"

if [ ! -x "$mise_bin" ]; then
  mkdir -p "{{ .chezmoi.homeDir }}/.local/bin"
  curl -fsSL https://mise.run | MISE_INSTALL_PATH="$mise_bin" MISE_VERSION="v$required_version" sh
else
  current_version=$("$mise_bin" --no-config version | /usr/bin/awk '{print $1}')
  oldest_version=$(printf '%s\n%s\n' "$current_version" "$required_version" | /usr/bin/sort -V | /usr/bin/head -n 1)

  if [ "$oldest_version" = "$current_version" ] && [ "$current_version" != "$required_version" ]; then
    "$mise_bin" --no-config self-update "$required_version" --yes --no-plugins
  fi
fi
