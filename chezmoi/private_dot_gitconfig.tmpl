[push]
	default = current
[color]
	ui = true
[core]
	excludesfile = ~/.gitignore_global
	autocrlf = input
	commentChar = %
	pager = hunk pager
[merge]
	ff = only
	conflictStyle = zdiff3
[pull]
	ff = only
	default = current
[rerere]
	enabled = true
	autoUpdate = true
[fetch]
	prune = true
	parallel = 0
[rebase]
	autosquash = true
	autostash = true
[user]
	name = khoi
	email = 6994441+khoi@users.noreply.github.com
{{ if eq .chezmoi.hostname "khoi-YY4J1XJ7F3" -}}
	signingkey = /Users/khoi/.ssh/id_ed25519_github.pub
{{ else -}}
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEIR0MxbYdOCgxOp1D27lGSjolzabibv88N2wplMbcbE
{{ end -}}
[commit]
	gpgsign = true
	status = false
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[gpg]
	format = ssh
{{ if ne .chezmoi.hostname "khoi-YY4J1XJ7F3" -}}
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
{{ end -}}
[alias]
	find = "!git log --color -S "
	nuke = "!git reset --hard && git clean -fd"
[submodule]
	recurse = true
	fetchJobs = 12
	alternatelocation = superproject
	alternateerrorstrategy = info
[checkout]
	workers = 0
[pack]
	threads = 0
[index]
	threads = 0
[gj]
	root = ~/code
