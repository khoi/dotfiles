{{- /* chezmoi:modify-template */ -}}
{{- $settings := dict -}}
{{- if .chezmoi.stdin -}}{{- $settings = fromJson .chezmoi.stdin -}}{{- end -}}
{{- $managed := fromJson `{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "warp@claude-code-warp": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "USE_BUILTIN_RIPGREP": "0"
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "repo": "warpdotdev/claude-code-warp",
        "source": "github"
      }
    }
  },
  "fileCheckpointingEnabled": false,
  "includeCoAuthoredBy": false,
  "model": "claude-fable-5[1m]",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Read(./.entire/metadata/**)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "~/.claude/cc-statusline-rs",
    "type": "command"
  },
  "syntaxHighlightingDisabled": true,
  "theme": "auto",
  "tui": "default"
}` -}}
{{- range $key, $value := $managed -}}{{- $settings = setValueAtPath $key $value $settings -}}{{- end -}}
{{- $settings | toPrettyJson -}}
